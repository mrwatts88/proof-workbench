# Per-developer harness overrides. The shared Claude Code configuration in
# .claude/settings.json and .claude/agents/ is committed.
.claude/settings.local.json

__pycache__/
*.py[cod]
.DS_Store
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Tectonic's build log is reproducible diagnostic output; the corresponding PDF
# is a committed publication artifact.
papers/build/*.log

# Generated experiment output should be ignored locally unless it is deliberately
# promoted as compact, reproducible evidence.
problems/*/experiments/*/generated/
